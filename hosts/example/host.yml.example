host: <droplet_ip>
port: 4444
user: <username>
playbook: provision-host.yml
vars:
  email_address: <email>
sites:
  site_key:
    domain: <domain>
    multisite: false
    theme_repo: <github_repo_url>
    # additional_content_repo: <github_repo_url>  # optional
    # webroot_dirs:                                # optional: dirs to copy from old host
    #   - images
